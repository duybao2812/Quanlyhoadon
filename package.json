{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:watch": "set NODE_ENV=development&& tsx watch server.ts",
    "build": "vite build",
    "build:wallpaper": "vite build --outDir d:/desktop-dashboard/quanlyhoadon --emptyOutDir && scripts\\\\sync-wallpaper.bat",
    "start": "node server.ts",
    "preview": "npm run build && set NODE_ENV=production&& tsx server.ts",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test:dashboard": "vitest run src/components/Dashboard/__tests__",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:preview": "npm run build && concurrently \"set NODE_ENV=production&& tsx server.ts\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.duybao2812.quanlyhoadon",
    "productName": "Quản Lý Hóa Đơn",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@floating-ui/react": "^0.27.19",
    "@google/genai": "^1.29.0",
    "@google/generative-ai": "^0.24.1",
    "@mistralai/mistralai": "^2.2.1",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.16.0",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "docx": "^9.7.1",
    "docxtemplater": "^3.68.6",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.10.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "openai": "^6.37.0",
    "pdfjs-dist": "^5.7.284",
    "pizzip": "^3.2.0",
    "playwright": "^1.61.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0",
    "vite": "^6.2.0",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vite-plugin-pwa": "^1.3.0",
    "xlsx": "^0.18.5",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.7",
    "wait-on": "^9.0.5"
  }
}
